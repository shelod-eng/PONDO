{
  "framework": "nextjs",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "web/.next",
  "crons": [
    {
      "path": "/api/pondo/admin/reports/cron/daily",
      "schedule": "30 4 * * *"
    },
    {
      "path": "/api/pondo/admin/reports/cron/weekly",
      "schedule": "0 5 * * 1"
    },
    {
      "path": "/api/pondo/admin/reports/cron/monthly",
      "schedule": "15 5 1 * *"
    }
  ]
}
